  "tokenColors": [
    {
      "name": "Comments",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#6C655D",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Keywords and storage",
      "scope": [
        "keyword",
        "keyword.package",
        "keyword.import",
        "keyword.function",
        "keyword.type",
        "keyword.other",
        "keyword.other.sql",
        "keyword.other.DML.sql",
        "keyword.other.DDL.sql",
        "storage.type",
        "storage.modifier",
        "keyword.control",
        "keyword.operator.word"
      ],
      "settings": {
        "foreground": "#B84A2A"
      }
    },
    {
      "name": "Operators",
      "scope": [
        "keyword.operator",
        "keyword.operator.sql",
        "punctuation.separator",
        "punctuation.accessor",
        "punctuation.terminator"
      ],
      "settings": {
        "foreground": "#6A645C"
      }
    },
    {
