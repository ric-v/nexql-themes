  "tokenColors": [
    {
      "name": "Comments",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#9D8FBF",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Keywords (quiet tier)",
      "scope": [
        "keyword",
        "keyword.package",
        "keyword.import",
        "keyword.function",
        "keyword.type",
        "keyword.other",
        "keyword.other.sql",
        "keyword.other.DML.sql",
        "keyword.other.DDL.sql",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#8E8FB8",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Operators and punctuation",
      "scope": [
        "keyword.operator",
        "keyword.operator.sql",
        "punctuation"
      ],
      "settings": {
        "foreground": "#8E8FB8"
      }
    },
    {
      "name": "Functions",
      "scope": [
        "entity.name.function",
        "support.function",
        "support.function.sql",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#9BBCE8"
      }
    },
    {
      "name": "Types",
      "scope": [
