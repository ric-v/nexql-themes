  "tokenColors": [
    {
      "name": "Comments",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#6B8499",
        "fontStyle": "italic"
      }
    },
    {
      "name": "SQL keywords",
      "scope": [
        "keyword",
        "keyword.package",
        "keyword.import",
        "keyword.function",
        "keyword.type",
        "keyword.other",
        "keyword.other.sql",
        "keyword.other.DML.sql",
        "keyword.other.DDL.sql",
        "storage.type",
        "storage.modifier",
        "keyword.control",
        "keyword.operator.word"
      ],
      "settings": {
        "foreground": "#2A5580"
      }
    },
    {
      "name": "Operators",
      "scope": [
        "keyword.operator",
