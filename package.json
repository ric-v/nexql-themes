{
  "name": "nexql-themes",
  "displayName": "NexQL Themes",
  "description": "NexQL theme family — scenario-anchored variants (quiet keywords, disciplined spectrum, one reserved accent).",
  "version": "0.0.6",
  "publisher": "ric-v",
  "repository": {
    "type": "git",
    "url": "https://github.com/ric-v/NexQL-Themes.git"
  },
  "license": "MIT",
  "icon": "nexql-theme-logo.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Themes"
  ],
  "keywords": [
    "theme",
    "dark theme",
    "light theme",
    "preview",
    "postgresql",
    "sql",
    "database",
    "nexql"
  ],
  "galleryBanner": {
    "color": "#f8f7f7",
    "theme": "light"
  },
  "extensionKind": [
    "workspace",
    "ui"
  ],
  "contributes": {
    "themes": [
      {
        "label": "NexQL Mute Dark",
        "uiTheme": "vs-dark",
        "path": "./themes/nexql-mute-dark-color-theme.json"
      },
      {
        "label": "NexQL OLED Dark",
        "uiTheme": "vs-dark",
        "path": "./themes/nexql-oled-dark-color-theme.json"
      },
      {
        "label": "NexQL Ember Dark",
        "uiTheme": "vs-dark",
        "path": "./themes/nexql-ember-dark-color-theme.json"
      },
      {
        "label": "NexQL Drift Dark",
        "uiTheme": "vs-dark",
        "path": "./themes/nexql-drift-dark-color-theme.json"
      },
      {
        "label": "NexQL Break of Dawn",
        "uiTheme": "vs",
        "path": "./themes/nexql-break-of-dawn-color-theme.json"
      },
      {
        "label": "NexQL Claudy Day",
        "uiTheme": "vs",
        "path": "./themes/nexql-claudy-day-color-theme.json"
      },
      {
        "label": "NexQL Claudy Night",
        "uiTheme": "vs-dark",
        "path": "./themes/nexql-claudy-night-color-theme.json"
      },
      {
        "label": "NexQL Postgres Homage Dark",
        "uiTheme": "vs-dark",
        "path": "./themes/nexql-postgres-homage-dark-color-theme.json"
      },
      {
        "label": "NexQL Postgres Homage Day",
        "uiTheme": "vs",
        "path": "./themes/nexql-postgres-homage-day-color-theme.json"
      },
      {
        "label": "NexQL Sage Day",
        "uiTheme": "vs",
        "path": "./themes/nexql-sage-day-color-theme.json"
      },
      {
        "label": "NexQL Sage at Night",
        "uiTheme": "vs-dark",
        "path": "./themes/nexql-sage-at-night-color-theme.json"
      }
    ]
  },
  "scripts": {
    "generate": "node scripts/generate-previews.mjs",
    "validate": "node scripts/validate-themes.mjs",
    "build:site": "node scripts/build-site.mjs",
    "compile": "npm run generate && npm run validate",
    "vscode:prepublish": "npm run compile",
    "watch": "npm run compile"
  }
}
